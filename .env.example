# Restore Engine
NODE_ENV=development
PORT=8090
RESTORE_ENGINE_PUBLIC_URL=http://localhost:8090
RESTORE_ENGINE_WEB_URL=http://localhost:5174

# Nexus bridge
NEXUS_SUPABASE_URL=https://your-project.supabase.co
NEXUS_SUPABASE_ANON_KEY=replace-me
NEXUS_SUPABASE_SERVICE_ROLE_KEY=replace-me-server-only
NEXUS_JWT_AUDIENCE=authenticated

# Restore engine database
RESTORE_DATABASE_URL=postgresql://postgres:postgres@localhost:54329/restore_engine

# Storage
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=.data/storage
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# AI assistant optional
ANTHROPIC_API_KEY=

# Security
MAX_UPLOAD_BYTES=1073741824
SIGNED_URL_SECRET=change-me
